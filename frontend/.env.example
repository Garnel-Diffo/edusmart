# ============================================================
# EduSmart Frontend (Next.js) - Variables d'environnement
# Copier en `.env.local` - jamais committé.
# ============================================================

# URL publique du backend Node/Express déployé sur Render
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# URL du serveur Socket.io (généralement = NEXT_PUBLIC_BACKEND_URL)
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Cloudinary cloud name (public - pour aperçu d'images, pas de signature ici)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
