# ===========================================================================
# EduSmart Backend — Variables d'environnement
# Copier ce fichier en `.env` et renseigner les valeurs réelles.
# Ne JAMAIS committer le fichier `.env`.
# ===========================================================================

# --- Application ---
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# --- Base de données (Neon.tech PostgreSQL) ---
# Format: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/edusmart?sslmode=require"
# Connexion directe (sans pgbouncer) requise par Prisma Migrate, si vous utilisez
# le pooling Neon pour DATABASE_URL, renseignez aussi DIRECT_URL.
DIRECT_URL="postgresql://user:password@ep-xxxx.neon.tech/edusmart?sslmode=require"

# --- Redis (Upstash) — protocole natif TLS ---
REDIS_URL="rediss://default:password@xxxx.upstash.io:6379"

# --- JWT ---
JWT_ACCESS_SECRET="change_me_access_secret_min_32_chars"
JWT_REFRESH_SECRET="change_me_refresh_secret_min_32_chars"
JWT_ACCESS_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="30d"

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- Brevo (emails transactionnels) ---
BREVO_API_KEY=""
BREVO_SENDER_EMAIL="no-reply@edusmart.app"
BREVO_SENDER_NAME="EduSmart"

# --- Service IA Python (FastAPI, interne) ---
AI_SERVICE_URL="http://localhost:8000"
AI_SERVICE_SECRET="change_me_shared_secret_with_ai_service"

# --- Sécurité ---
BCRYPT_COST=12
RATE_LIMIT_PER_MINUTE=100
CORS_ALLOWED_ORIGINS="http://localhost:3000"

# --- Verrouillage de compte ---
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# --- Documents officiels ---
ETABLISSEMENT_NOM="École Nationale Supérieure Polytechnique de Yaoundé"
SEUIL_ADMISSION=10
