# ===========================================================================
# EduSmart - Service IA Python (FastAPI) — Variables d'environnement
# Copier ce fichier en `.env` et renseigner les valeurs réelles.
# ===========================================================================

ENVIRONMENT=development
PORT=8000

# --- Base de données (la même instance Neon que le backend Node, accès direct
# pour la table document_chunk avec pgvector) ---
DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/edusmart?sslmode=require"

# --- Sécurité : secret partagé avec le backend Node (en-tête X-Internal-Secret) ---
INTERNAL_SECRET="change_me_shared_secret_with_ai_service"

# --- Backend Node (pour le callback de fin de génération de fiche) ---
BACKEND_URL="http://localhost:4000"

# --- Groq (LLM) ---
GROQ_API_KEY=""
GROQ_MODEL="openai/gpt-oss-120b"

# --- Embeddings ---
EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"
EMBEDDING_DIMENSIONS=384

# --- RAG ---
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
CHUNK_SIZE_CHARS=1000
CHUNK_OVERLAP_CHARS=150
